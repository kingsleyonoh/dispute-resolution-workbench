# Runtime
APP_ENV=development
PORT=3049
LOG_LEVEL=info
DEMO_MODE=true

# Database
DATABASE_URL=xxxxx
DATABASE_POOL=10
DATOMIC_URI=xxxxx

# Cache
REDIS_URL=redis://localhost:6379/0

# Tenant management
SELF_REGISTRATION_ENABLED=true
API_KEY_PREFIX=drw_live_

# Auth / UI session
SESSION_SECRET=xxxxx
SESSION_COOKIE_NAME=drw_session
SESSION_MAX_AGE_SECONDS=86400

# CORS
ALLOWED_ORIGINS=http://localhost:3049,https://disputes.kingsleyonoh.com

# Ecosystem - Notification Hub
NOTIFICATION_HUB_ENABLED=false
NOTIFICATION_HUB_URL=https://notify.kingsleyonoh.com
NOTIFICATION_HUB_API_KEY=xxxxx

# Ecosystem - Workflow Engine
WORKFLOW_ENGINE_ENABLED=false
WORKFLOW_ENGINE_URL=https://workflows.kingsleyonoh.com
WORKFLOW_ENGINE_API_KEY=xxxxx

# Ecosystem - Invoice Reconciliation Engine
INVOICE_RECON_ENABLED=false
INVOICE_RECON_URL=xxxxx
INVOICE_RECON_API_KEY=xxxxx
INVOICE_RECON_POLL_INTERVAL_SECONDS=600

# Ecosystem - Contract Lifecycle Engine
CONTRACT_LIFECYCLE_ENABLED=false
CONTRACT_LIFECYCLE_URL=xxxxx
CONTRACT_LIFECYCLE_API_KEY=xxxxx
CONTRACT_LIFECYCLE_BACKFILL_INTERVAL_SECONDS=900

# NATS
NATS_ENABLED=false
NATS_URL=nats://localhost:4222
NATS_CREDS_PATH=xxxxx
NATS_STREAM_NAME=ECOSYSTEM_EVENTS

# Ecosystem - Transaction Reconciliation Engine
TRANSACTION_RECON_ENABLED=false
TRANSACTION_RECON_URL=xxxxx
TRANSACTION_RECON_API_KEY=xxxxx
TRANSACTION_RECON_POLL_INTERVAL_SECONDS=900

# Ecosystem - Webhook Ingestion Engine
WEBHOOK_ENGINE_ENABLED=false
WEBHOOK_ENGINE_URL=xxxxx
WEBHOOK_ENGINE_API_KEY=xxxxx
WEBHOOK_ENGINE_DLQ_POLL_INTERVAL_SECONDS=1800

# Hub ingress
HUB_INGRESS_SECRET=xxxxx

# Scoring / correlation
AUTO_MERGE_THRESHOLD=0.92
REVIEW_THRESHOLD=0.70
CORRELATION_WINDOW_DAYS=14
MAX_INGESTION_BATCH_SIZE=100
DEFAULT_SLA_MINUTES=7200
SLA_REAPER_INTERVAL_SECONDS=300
RESOLUTION_POLL_INTERVAL_SECONDS=30

# Observability
SENTRY_DSN=xxxxx
AXIOM_TOKEN=xxxxx
AXIOM_DATASET=drw-logs
POSTHOG_API_KEY=xxxxx
POSTHOG_HOST=xxxxx
PROMETHEUS_ENABLED=true
METRICS_BASIC_AUTH_USER=metrics
METRICS_BASIC_AUTH_PASS=xxxxx

# First-run seed
AUTO_SEED=true
